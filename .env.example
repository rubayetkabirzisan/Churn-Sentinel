# Copy this file to .env and fill in values
# No secrets needed for local-only setup

# Model config
CHURN_THRESHOLD=0.65
MODEL_PATH=outputs/xgb_model.pkl

# Ollama config (local LLM - free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Email simulation (no real key needed)
EMAIL_SIMULATION_MODE=true
EMAIL_LOG_PATH=outputs/email_log.json